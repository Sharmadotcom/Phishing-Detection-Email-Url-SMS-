# PhishGuard — API Configuration
# Rename this file to .env and fill in your keys

# VirusTotal API Key (Optional, get free key at virustotal.com)
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# Google Safe Browsing API Key (Optional, get free key at console.cloud.google.com)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_key_here
